  "dependencies": {
    "@6njp/prototype-library": "github:rinus-vh/prototype-library",
    "@floating-ui/react": "^0.27.19",
    "@huggingface/transformers": "^4.2.0",
    "@mediapipe/tasks-vision": "0.10.35",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@use-gesture/react": "^10.3.1",
    "keen-slider": "^6.8.6",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@6njp/eslint-plugin": "github:rinus-vh/plugins#path:eslint-plugin",
    "@6njp/stylelint-plugin": "github:rinus-vh/plugins#path:stylelint-plugin",
    "@eslint/js": "^9.39.4",
    "@react-three/eslint-plugin": "^0.1.2",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "stylelint": "^17.13.0",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.0.8",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "onnxruntime-node",
      "protobufjs",
      "sharp"
